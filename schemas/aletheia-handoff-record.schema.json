{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aletheia.local/schemas/handoff-record.schema.json",
  "title": "AletheIA Handoff Record",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "task_brief_id", "origin", "status", "completed", "pending", "risks", "reopen_context"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "task_brief_id": { "type": "string", "minLength": 1 },
    "origin": {
      "type": "object",
      "additionalProperties": false,
      "required": ["actor", "thread", "date"],
      "properties": {
        "actor": { "type": "string", "minLength": 1 },
        "thread": { "type": "string", "minLength": 1 },
        "date": { "type": "string", "format": "date-time" }
      }
    },
    "status": { "type": "string", "enum": ["planned", "in_progress", "blocked", "ready_for_validation", "done"] },
    "completed": { "type": "array", "items": { "type": "string" } },
    "pending": { "type": "array", "items": { "type": "string" } },
    "risks": { "type": "array", "items": { "type": "string" } },
    "reopen_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary", "required_files", "next_action"],
      "properties": {
        "summary": { "type": "string", "minLength": 1 },
        "required_files": { "type": "array", "items": { "type": "string" } },
        "next_action": { "type": "string", "minLength": 1 }
      }
    },
    "validation_next": { "type": "array", "items": { "type": "string" } }
  }
}
