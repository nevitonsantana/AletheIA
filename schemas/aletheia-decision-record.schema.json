{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aletheia.local/schemas/decision-record.schema.json",
  "title": "AletheIA Decision Record",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "task_brief_id", "input", "context_snapshot", "interpretation", "decision", "justification", "provenance", "metadata"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "task_brief_id": { "type": "string", "minLength": 1 },
    "input": {
      "type": "object",
      "additionalProperties": true,
      "required": ["signal"],
      "properties": {
        "signal": { "type": "string", "minLength": 1 },
        "raw": {}
      }
    },
    "context_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary", "sources_considered"],
      "properties": {
        "summary": { "type": "string", "minLength": 1 },
        "sources_considered": { "type": "array", "items": { "type": "string" } },
        "omitted_context": { "type": "array", "items": { "type": "string" } }
      }
    },
    "interpretation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary", "key_signals"],
      "properties": {
        "summary": { "type": "string", "minLength": 1 },
        "key_signals": { "type": "array", "items": { "type": "string" } },
        "assumptions": { "type": "array", "items": { "type": "string" } }
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action"],
      "properties": {
        "action": { "type": "string", "enum": ["allow", "continue", "review", "fallback", "retry", "block", "ask_human"] },
        "target": { "type": "string" },
        "next_step": { "type": "string" }
      }
    },
    "justification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reason"],
      "properties": {
        "reason": { "type": "string", "minLength": 1 },
        "policy_refs": { "type": "array", "items": { "type": "string" } }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["facts", "inferences", "rules_applied"],
      "properties": {
        "facts": { "type": "array", "items": { "type": "string" } },
        "inferences": { "type": "array", "items": { "type": "string" } },
        "rules_applied": { "type": "array", "items": { "type": "string" } }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["confidence", "risk", "trace_id", "created_at"],
      "properties": {
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "risk": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "trace_id": { "type": "string", "minLength": 1 },
        "created_at": { "type": "string", "format": "date-time" }
      }
    }
  }
}
